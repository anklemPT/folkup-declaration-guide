# SECURE ENVIRONMENT CONFIGURATION TEMPLATE
# Production deployment environment variables
# SECURITY: Replace with actual values during deployment

# Core Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# Dashboard Aggregator Configuration
AGGREGATOR_ENABLED=true
CACHE_TTL_SEC=45
RATE_LIMIT_WARN_THRESHOLD=80

# JWT Authentication (REQUIRED - Generate 32+ character secret)
JWT_SECRET=REPLACE_WITH_SECURE_JWT_SECRET_MINIMUM_32_CHARACTERS

# GitHub API Access (Read-only Personal Access Token)
GH_PAT_READONLY=REPLACE_WITH_GITHUB_PAT

# Uptime Kuma Integration
KUMA_URL=REPLACE_WITH_KUMA_URL
KUMA_TOKEN=REPLACE_WITH_KUMA_TOKEN

# CrowdSec LAPI Integration
CROWDSEC_LAPI_URL=REPLACE_WITH_CROWDSEC_URL
CROWDSEC_LAPI_KEY=REPLACE_WITH_CROWDSEC_KEY

# ================================================================================
# SECURITY INSTRUCTIONS:
# 1. Copy this template to .env.production
# 2. Replace ALL "REPLACE_WITH_*" values with actual secrets
# 3. Set file permissions: chmod 600 .env.production
# 4. NEVER commit .env.production to version control
# 5. Use docker-compose.secure.yml for deployment
# ================================================================================