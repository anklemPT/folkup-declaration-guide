# precommit:allow-ai-mentions
# Enhanced .gitignore for Sensitive File Protection
# Updated 2026-05-15 - SYS-003 Security gaps remediation

# Claude Code specific
.claude/
deployment.zip

# Environment variables and secrets
.env
.env.*
!.env.example
*.env
*.env.*
!*.env.example
.env.local
secrets.json
secrets.yaml
secrets.yml
credentials.json
credentials*.json
.credentials.json
credentials.yaml
credentials.yml
config.secret.*
*.secret
settings.local.json

# API Keys and tokens
*api*key*
*token*
*secret*
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer

# SOPS encrypted files (exclude from git - should be in separate secure repo)
*.sops.*

# Docker secrets
docker-compose.override.yml
docker-compose.secrets.yml

# Backup files that might contain sensitive data
*.backup
*.bak
*.old
*.tmp
*~
.#*
\#*#
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE and editor files
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.idea/
*.sublime-project
*.sublime-workspace
*~

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Dependency directories
node_modules/
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# SSH keys
id_rsa
id_rsa.pub
id_dsa
id_dsa.pub
id_ecdsa
id_ecdsa.pub
id_ed25519
id_ed25519.pub
*.ppk

# GPG keys
*.gpg
*.asc

# Certificate files
*.p12
*.pfx
*.crt
*.cer
*.key
*.pem

# Database files
*.db
*.sqlite
*.sqlite3

# Compressed files that might contain sensitive data
*.zip
*.tar.gz
*.rar
*.7z

# Temporary directories
tmp/
temp/
cache/

# System configuration directories
.gnupg/
.ssh/
.aws/
.docker/config.json

# Personal notes and TODO files that might contain sensitive info
TODO.private
NOTES.private
*.private

# Cloudflare and other service configs
cloudflare.ini
wrangler.toml

# Age encryption keys
*.age
key.txt
keys.txt

# Local development configuration
local.config.*
dev.config.*
test.config.*

# Windows specific
$RECYCLE.BIN/

# MacOS specific
.AppleDouble
.LSOverride

# Linux specific
*~

# Backup files from editors
*.orig
*.rej
# System and user directories (prevent future bloat)
AppData/
Documents/
Downloads/
My Documents/
Contacts/
Creative Cloud Files/
CrossDevice/
OneDrive/

# Personal dotfiles
.cache/
.config/
.local/
.bash_history
.bash_profile
.gitconfig
.gitignore_global

# Personal documents
*.csv
comprovativo_*

dist/
