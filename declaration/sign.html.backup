<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign the Declaration — FolkUp</title>
  <meta name="description" content="Sign The Unenclosed Knowledge Declaration — Add your voice to the movement for open knowledge.">
  <meta property="og:title" content="Sign the Declaration — FolkUp">
  <meta property="og:description" content="Add your voice to the movement for open knowledge. Sign the Unenclosed Knowledge Declaration.">
  <meta property="og:image" content="/images/og-folkup.png">
  <meta property="og:url" content="https://declaration.folkup.app/sign">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <style>
    @font-face { font-family: 'Instrument Serif'; font-style: normal; font-weight: 400; font-display: swap; src: url(/fonts/instrument-serif-normal-latin-ext.woff2) format('woff2'); unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF; }
    @font-face { font-family: 'Instrument Serif'; font-style: normal; font-weight: 400; font-display: swap; src: url(/fonts/instrument-serif-normal-latin.woff2) format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }
    @font-face { font-family: 'Instrument Serif'; font-style: italic; font-weight: 400; font-display: swap; src: url(/fonts/instrument-serif-italic-latin-ext.woff2) format('woff2'); unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF; }
    @font-face { font-family: 'Instrument Serif'; font-style: italic; font-weight: 400; font-display: swap; src: url(/fonts/instrument-serif-italic-latin.woff2) format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }
    @font-face { font-family: 'Playfair Display'; font-style: normal; font-weight: 400; font-display: swap; src: url(/fonts/playfair-normal-cyrillic.woff2) format('woff2'); unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116; }
    @font-face { font-family: 'Playfair Display'; font-style: normal; font-weight: 400; font-display: swap; src: url(/fonts/playfair-normal-latin.woff2) format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }
    @font-face { font-family: 'Playfair Display'; font-style: normal; font-weight: 700; font-display: swap; src: url(/fonts/playfair-bold-cyrillic.woff2) format('woff2'); unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116; }
    @font-face { font-family: 'Playfair Display'; font-style: normal; font-weight: 700; font-display: swap; src: url(/fonts/playfair-bold-latin.woff2) format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 300 700; font-display: swap; src: url(/fonts/inter-cyrillic-ext.woff2) format('woff2'); unicode-range: U+0460-052F, U+1C80-1C8A, U+20B4, U+2DE0-2DFF, U+A640-A69F, U+FE2E-FE2F; }
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 300 700; font-display: swap; src: url(/fonts/inter-cyrillic.woff2) format('woff2'); unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116; }
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 300 700; font-display: swap; src: url(/fonts/inter-latin-ext.woff2) format('woff2'); unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF; }
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 300 700; font-display: swap; src: url(/fonts/inter-latin.woff2) format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }

    :root {
      --bordo: #5E2F3A;
      --bordo-light: #7D4450;
      --sage: #4E6B42;
      --sage-light: #839E75;
      --amber: #E8AD4A;
      --bg: #FEFCF6;
      --text: #1a1a1a;
      --muted: #777;
      --border: #e2ddd5;
      --light: #f0ede6;
      color-scheme: light only;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    /* Skip to content link for keyboard navigation */
    .skip-link {
      position: absolute;
      top: -40px;
      left: 6px;
      background: var(--amber);
      color: var(--text);
      padding: 8px;
      text-decoration: none;
      border-radius: 4px;
      font-weight: 600;
      z-index: 1000;
      transition: top 0.2s;
    }
    .skip-link:focus {
      top: 6px;
    }

    /* Header */
    .header {
      background: var(--bordo);
      color: #fff;
      padding: 1.25rem 2rem;
    }
    .header-inner {
      max-width: 860px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .brand {
      font-family: 'Instrument Serif', serif;
      font-size: 1.5rem;
      color: #fff;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .brand:hover { opacity: 0.9; }
    .brand:focus-visible {
      outline: 2px solid var(--amber);
      outline-offset: 2px;
      border-radius: 2px;
    }
    .brand-logo {
      width: 24px;
      height: 24px;
      filter: brightness(0) invert(1);
    }
    .brand-text {
      font-size: inherit;
    }
    nav { display: flex; gap: 1.5rem; flex-wrap: wrap; }
    .nav-link {
      color: rgba(255,255,255,0.8);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      padding: 0.25rem 0;
      border-bottom: 2px solid transparent;
      transition: color 0.2s, border-color 0.2s;
    }
    .nav-link:hover { color: #fff; }
    .nav-link.active { color: #fff; border-bottom-color: #fff; }
    .nav-link:focus-visible {
      outline: 2px solid var(--amber);
      outline-offset: 2px;
      border-radius: 2px;
    }

    /* Hero */
    .hero {
      background: linear-gradient(180deg, var(--bordo) 0%, #3d1c24 100%);
      color: #fff;
      padding: 2.5rem 2rem 2rem;
      text-align: center;
    }
    .hero-inner { max-width: 700px; margin: 0 auto; }
    .hero h1 {
      font-family: 'Instrument Serif', serif;
      font-size: clamp(1.6rem, 4vw, 2.2rem);
      font-weight: 400;
      line-height: 1.3;
      margin-bottom: 0.75rem;
    }
    .hero p {
      font-size: 1rem;
      opacity: 0.85;
      line-height: 1.6;
    }
    [lang="ru"] .hero h1 { font-family: 'Playfair Display', Georgia, serif; }

    /* Language tabs */
    .lang-tabs {
      display: flex;
      justify-content: center;
      gap: 0.25rem;
      padding: 1rem 2rem 0;
      max-width: 860px;
      margin: 0 auto;
    }
    .lang-tab {
      background: none;
      border: 1px solid var(--border);
      border-bottom: none;
      padding: 0.5rem 1.25rem;
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--muted);
      cursor: pointer;
      border-radius: 6px 6px 0 0;
      transition: color 0.2s, background 0.2s;
      min-height: 44px;
      min-width: 44px;
    }
    .lang-tab:hover { color: var(--text); background: var(--light); }
    .lang-tab.active {
      color: var(--bordo);
      background: var(--bg);
      border-color: var(--bordo);
      font-weight: 600;
    }
    .lang-tab:focus-visible {
      outline: 2px solid var(--amber);
      outline-offset: 2px;
    }

    /* Content */
    .content {
      max-width: 860px;
      margin: 0 auto;
      padding: 2rem 2rem 3rem;
      border-top: 2px solid var(--bordo);
    }
    .lang-content { display: none; }
    .lang-content.active { display: block; }

    .content h2 {
      font-family: 'Instrument Serif', serif;
      font-size: 1.4rem;
      color: var(--bordo);
      margin-bottom: 1rem;
      line-height: 1.4;
    }
    [data-lang="ru"] h2 { font-family: 'Playfair Display', Georgia, serif; }

    .content p {
      margin-bottom: 1.25rem;
      color: var(--text);
      font-size: 0.95rem;
    }

    /* Form Styles */
    .form-container {
      background: #fff;
      border-radius: 12px;
      border: 1px solid var(--border);
      box-shadow: 0 4px 20px rgba(0,0,0,0.05);
      padding: 2rem;
      margin-top: 1.5rem;
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    .form-label {
      display: block;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: var(--text);
      font-size: 0.9rem;
    }

    .form-input {
      width: 100%;
      padding: 0.875rem;
      border: 2px solid var(--border);
      border-radius: 8px;
      font-family: 'Inter', sans-serif;
      font-size: 0.95rem;
      background: var(--bg);
      color: var(--text);
      transition: border-color 0.2s, box-shadow 0.2s;
      min-height: 44px;
    }

    .form-input:focus {
      outline: none;
      border-color: var(--sage);
      box-shadow: 0 0 0 3px rgba(78, 107, 66, 0.1);
    }

    .form-input:invalid:not(:focus) {
      border-color: #dc3545;
    }

    .form-select {
      appearance: none;
      background-image: url("data:image/svg+xml;charset=US-ASCII,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 4 5'><path fill='%23666' d='m0 1 2 2 2-2z'/></svg>");
      background-repeat: no-repeat;
      background-position: right 0.875rem center;
      background-size: 12px;
      padding-right: 2.5rem;
    }

    .form-required {
      color: #dc3545;
      margin-left: 0.25rem;
    }

    .form-help {
      font-size: 0.8rem;
      color: var(--muted);
      margin-top: 0.25rem;
    }

    .submit-btn {
      background: linear-gradient(135deg, var(--sage) 0%, var(--sage-light) 100%);
      color: #fff;
      border: none;
      padding: 1rem 2rem;
      font-size: 1rem;
      font-weight: 600;
      border-radius: 8px;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
      min-height: 44px;
      min-width: 120px;
      font-family: 'Inter', sans-serif;
    }

    .submit-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(78, 107, 66, 0.25);
    }

    .submit-btn:focus-visible {
      outline: 2px solid var(--amber);
      outline-offset: 2px;
    }

    .submit-btn:active {
      transform: translateY(0);
    }

    /* Privacy Notice */
    .privacy-notice {
      background: var(--light);
      border-left: 4px solid var(--amber);
      padding: 1rem;
      margin: 1.5rem 0;
      font-size: 0.85rem;
      border-radius: 0 6px 6px 0;
    }

    .privacy-notice a {
      color: var(--bordo);
      text-decoration: underline;
    }

    /* Mobile Responsive */
    @media (max-width: 768px) {
      .header { padding: 1rem; }
      .hero { padding: 1.5rem 1rem; }
      .content { padding: 1.5rem 1rem; }
      .form-container { padding: 1.5rem; margin-top: 1rem; }
      .lang-tabs { padding: 1rem 1rem 0; }
    }

    @media (max-width: 600px) {
      .header-inner { flex-direction: column; gap: 0.75rem; }
      nav { justify-content: center; }
      .lang-tabs { gap: 0.125rem; }
      .lang-tab {
        padding: 0.4rem 1rem;
        font-size: 0.8rem;
      }
    }

    /* Print styles */
    @media print {
      .header, .lang-tabs, .submit-btn { display: none; }
      .form-container { box-shadow: none; border: 1px solid #000; }
    }

    /* Reduced motion */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</head>
<body>
  <!-- Skip to main content for keyboard users -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <header class="header" role="banner">
    <div class="header-inner">
      <a href="/" class="brand">
        <img src="/images/folkup-lantern.png" alt="FolkUp" class="brand-logo">
        <span class="brand-text">FolkUp</span>
      </a>
      <nav role="navigation" aria-label="Main navigation">
        <a href="/" class="nav-link">Declaration</a>
        <a href="/guide/" class="nav-link">Guide</a>
        <a href="/sign" class="nav-link active" aria-current="page">Sign</a>
      </nav>
    </div>
  </header>

  <section class="hero" role="banner" aria-labelledby="hero-title">
    <div class="hero-inner">
      <div class="lang-content active" data-lang="en">
        <h1 id="hero-title">Sign the Declaration</h1>
        <p class="subtitle">Join the movement for open knowledge</p>
      </div>
      <div class="lang-content" data-lang="ru">
        <h1 id="hero-title">Подписать Декларацию</h1>
        <p class="subtitle">Присоединяйтесь к движению за открытое знание</p>
      </div>
      <div class="lang-content" data-lang="pt">
        <h1 id="hero-title">Assinar a Declaração</h1>
        <p class="subtitle">Junte-se ao movimento pelo conhecimento livre</p>
      </div>
    </div>
  </section>

  <!-- Language Selection Tabs -->
  <div class="lang-tabs">
    <button class="lang-tab language-tab active" data-lang="en" aria-label="Switch to English">EN</button>
    <button class="lang-tab language-tab" data-lang="ru" aria-label="Switch to Russian">РУ</button>
    <button class="lang-tab language-tab" data-lang="pt" aria-label="Switch to Portuguese">PT</button>
  </div>

  <main id="main-content" class="content" role="main">
    <!-- English Content -->
    <div class="lang-content active" data-lang="en">
      <h2>Add Your Voice</h2>
      <p>By signing the Unenclosed Knowledge Declaration, you're joining a global community committed to keeping knowledge open and accessible to all. Your signature helps demonstrate broad support for these principles.</p>

      <div class="form-container">
        <form action="https://formsubmit.co/anklemqq@gmail.com" method="POST" id="sign-form">
          <!-- FormSubmit.co hidden fields -->
          <input type="hidden" name="_subject" value="New Declaration Signature (EN)">
          <input type="hidden" name="_next" value="https://declaration.folkup.app/thank-you-en.html">
          <input type="hidden" name="_captcha" value="false">
          <input type="hidden" name="_template" value="table">
          <input type="hidden" name="preferred_language" value="en" id="lang-preference">

          <div class="form-group">
            <label for="name" class="form-label">Your Name <span class="form-required" aria-label="required">*</span></label>
            <input type="text" id="name" name="name" class="form-input" required maxlength="100"
                   placeholder="Enter your full name" aria-describedby="name-help">
            <div class="form-help" id="name-help">This is how your name will appear as a signatory.</div>
          </div>

          <div class="form-group">
            <label for="email" class="form-label">Email Address <span class="form-required" aria-label="required">*</span></label>
            <input type="email" id="email" name="email" class="form-input" required maxlength="100"
                   placeholder="your@email.com" aria-describedby="email-help">
            <div class="form-help" id="email-help">We'll only use this to confirm your signature and send important updates.</div>
          </div>

          <div class="form-group">
            <label for="organization" class="form-label">Organization (Optional)</label>
            <input type="text" id="organization" name="organization" class="form-input" maxlength="150"
                   placeholder="Your company, university, or organization" aria-describedby="org-help">
            <div class="form-help" id="org-help">If you're signing on behalf of or representing an organization.</div>
          </div>

          <div class="privacy-notice">
            <p><strong>Privacy Notice:</strong> By submitting this form, you consent to your name being displayed publicly as a signatory to the Declaration. Your email address will not be published. See our <a href="/privacy" target="_blank" rel="noopener">Privacy Policy</a> for full details.</p>
          </div>

          <button type="submit" class="submit-btn">Sign the Declaration</button>
        </form>
      </div>
    </div>

    <!-- Russian Content -->
    <div class="lang-content" data-lang="ru">
      <h2>Добавьте свой голос</h2>
      <p>Подписав Декларацию незакрытого знания, вы присоединяетесь к глобальному сообществу, приверженному сохранению знаний открытыми и доступными для всех. Ваша подпись помогает продемонстрировать широкую поддержку этих принципов.</p>

      <div class="form-container">
        <form action="https://formsubmit.co/anklemqq@gmail.com" method="POST" id="sign-form-ru">
          <!-- FormSubmit.co hidden fields -->
          <input type="hidden" name="_subject" value="New Declaration Signature (RU)">
          <input type="hidden" name="_next" value="https://declaration.folkup.app/thank-you-ru.html">
          <input type="hidden" name="_captcha" value="false">
          <input type="hidden" name="_template" value="table">
          <input type="hidden" name="preferred_language" value="ru" id="lang-preference-ru">

          <div class="form-group">
            <label for="name-ru" class="form-label">Ваше имя <span class="form-required" aria-label="обязательно">*</span></label>
            <input type="text" id="name-ru" name="name" class="form-input" required maxlength="100"
                   placeholder="Введите ваше полное имя" aria-describedby="name-help-ru">
            <div class="form-help" id="name-help-ru">Так ваше имя будет отображаться в списке подписантов.</div>
          </div>

          <div class="form-group">
            <label for="email-ru" class="form-label">Адрес электронной почты <span class="form-required" aria-label="обязательно">*</span></label>
            <input type="email" id="email-ru" name="email" class="form-input" required maxlength="100"
                   placeholder="ваш@email.ru" aria-describedby="email-help-ru">
            <div class="form-help" id="email-help-ru">Мы используем это только для подтверждения вашей подписи и важных обновлений.</div>
          </div>

          <div class="form-group">
            <label for="organization-ru" class="form-label">Организация (необязательно)</label>
            <input type="text" id="organization-ru" name="organization" class="form-input" maxlength="150"
                   placeholder="Ваша компания, университет или организация" aria-describedby="org-help-ru">
            <div class="form-help" id="org-help-ru">Если вы подписываетесь от имени организации.</div>
          </div>

          <div class="privacy-notice">
            <p><strong>Уведомление о конфиденциальности:</strong> Отправляя эту форму, вы соглашаетесь на публичное отображение вашего имени как подписанта Декларации. Ваш адрес электронной почты не будет опубликован. Полные подробности см. в нашей <a href="/privacy" target="_blank" rel="noopener">Политике конфиденциальности</a>.</p>
          </div>

          <button type="submit" class="submit-btn">Подписать Декларацию</button>
        </form>
      </div>
    </div>

    <!-- Portuguese Content -->
    <div class="lang-content" data-lang="pt">
      <h2>Adicione Sua Voz</h2>
      <p>Ao assinar a Declaração do Conhecimento Livre, você está se juntando a uma comunidade global comprometida em manter o conhecimento aberto e acessível a todos. Sua assinatura ajuda a demonstrar amplo apoio a esses princípios.</p>

      <div class="form-container">
        <form action="https://formsubmit.co/anklemqq@gmail.com" method="POST" id="sign-form-pt">
          <!-- FormSubmit.co hidden fields -->
          <input type="hidden" name="_subject" value="New Declaration Signature (PT)">
          <input type="hidden" name="_next" value="https://declaration.folkup.app/thank-you-pt.html">
          <input type="hidden" name="_captcha" value="false">
          <input type="hidden" name="_template" value="table">
          <input type="hidden" name="preferred_language" value="pt" id="lang-preference-pt">

          <div class="form-group">
            <label for="name-pt" class="form-label">Seu Nome <span class="form-required" aria-label="obrigatório">*</span></label>
            <input type="text" id="name-pt" name="name" class="form-input" required maxlength="100"
                   placeholder="Digite seu nome completo" aria-describedby="name-help-pt">
            <div class="form-help" id="name-help-pt">É assim que seu nome aparecerá como signatário.</div>
          </div>

          <div class="form-group">
            <label for="email-pt" class="form-label">Endereço de Email <span class="form-required" aria-label="obrigatório">*</span></label>
            <input type="email" id="email-pt" name="email" class="form-input" required maxlength="100"
                   placeholder="seu@email.com" aria-describedby="email-help-pt">
            <div class="form-help" id="email-help-pt">Usaremos apenas para confirmar sua assinatura e enviar atualizações importantes.</div>
          </div>

          <div class="form-group">
            <label for="organization-pt" class="form-label">Organização (Opcional)</label>
            <input type="text" id="organization-pt" name="organization" class="form-input" maxlength="150"
                   placeholder="Sua empresa, universidade ou organização" aria-describedby="org-help-pt">
            <div class="form-help" id="org-help-pt">Se você está assinando em nome de uma organização.</div>
          </div>

          <div class="privacy-notice">
            <p><strong>Aviso de Privacidade:</strong> Ao enviar este formulário, você consente que seu nome seja exibido publicamente como signatário da Declaração. Seu endereço de email não será publicado. Consulte nossa <a href="/privacy" target="_blank" rel="noopener">Política de Privacidade</a> para detalhes completos.</p>
          </div>

          <button type="submit" class="submit-btn">Assinar a Declaração</button>
        </form>
      </div>
    </div>
  </main>

  <script>
    // Language switching functionality - adapted from index.html
    function switchLanguage(lang) {
      // Hide all content
      document.querySelectorAll('.lang-content').forEach(el => {
        el.style.display = 'none';
        el.classList.remove('active');
      });

      // Show target language content
      document.querySelectorAll(`.lang-content[data-lang="${lang}"]`).forEach(el => {
        el.style.display = 'block';
        el.classList.add('active');
      });

      // Update active tab
      document.querySelectorAll('.language-tab').forEach(tab => {
        tab.classList.remove('active');
      });
      const activeTab = document.querySelector(`.language-tab[data-lang="${lang}"]`);
      if (activeTab) activeTab.classList.add('active');

      // Update page language
      document.documentElement.lang = lang === 'ru' ? 'ru' : lang === 'pt' ? 'pt' : 'en';

      // Update hidden language preference fields in all forms
      const langFields = document.querySelectorAll('input[name="preferred_language"]');
      langFields.forEach(field => field.value = lang);

      // Update form subjects based on language
      const subjectFields = document.querySelectorAll('input[name="_subject"]');
      subjectFields.forEach(field => {
        if (lang === 'ru') {
          field.value = 'New Declaration Signature (RU)';
        } else if (lang === 'pt') {
          field.value = 'New Declaration Signature (PT)';
        } else {
          field.value = 'New Declaration Signature (EN)';
        }
      });

      // Update success redirect URLs
      const nextFields = document.querySelectorAll('input[name="_next"]');
      nextFields.forEach(field => {
        field.value = `https://declaration.folkup.app/thank-you-${lang}.html`;
      });
    }

    // URL detection and routing
    function detectLanguageFromURL() {
      const path = window.location.pathname;
      if (path.includes('/ru/')) return 'ru';
      if (path.includes('/pt/')) return 'pt';
      if (path.includes('/en/')) return 'en';
      return 'en'; // default
    }

    // Get language from localStorage or URL or browser default
    function getPreferredLanguage() {
      // 1. Check localStorage first
      const saved = localStorage.getItem('preferredLanguage');
      if (saved && ['en', 'ru', 'pt'].includes(saved)) {
        return saved;
      }

      // 2. Fall back to URL detection
      const urlLang = detectLanguageFromURL();
      if (urlLang !== 'en') {
        return urlLang;
      }

      // 3. Detect browser language
      const browserLang = navigator.language.split('-')[0];
      if (browserLang === 'ru' || browserLang === 'pt') {
        return browserLang;
      }

      return 'en'; // default
    }

    // Save language preference
    function saveLanguagePreference(lang) {
      localStorage.setItem('preferredLanguage', lang);
    }

    // Initialize page
    function init() {
      const currentLang = getPreferredLanguage();
      switchLanguage(currentLang);

      // Update URL if needed
      if (currentLang !== 'en') {
        const newPath = `/sign/${currentLang}/`;
        history.replaceState({lang: currentLang}, '', newPath);
      }

      // Language tab click handlers
      document.querySelectorAll('.language-tab').forEach(tab => {
        tab.addEventListener('click', function(e) {
          e.preventDefault();
          const lang = this.dataset.lang;

          // Save preference and update URL with pushState
          saveLanguagePreference(lang);
          const newPath = lang === 'en' ? '/sign' : `/sign/${lang}/`;
          history.pushState({lang}, '', newPath);
          switchLanguage(lang);
        });
      });

      // Form validation enhancement
      const forms = document.querySelectorAll('form[id^="sign-form"]');
      forms.forEach(form => {
        form.addEventListener('submit', function(e) {
          const nameField = form.querySelector('input[name="name"]');
          const emailField = form.querySelector('input[name="email"]');

          // Basic validation (browsers will handle most of this with HTML5)
          if (!nameField.value.trim()) {
            nameField.focus();
            e.preventDefault();
            return false;
          }

          if (!emailField.value.trim() || !emailField.validity.valid) {
            emailField.focus();
            e.preventDefault();
            return false;
          }

          // Optional: Show loading state
          const submitBtn = form.querySelector('.submit-btn');
          submitBtn.style.opacity = '0.6';
          submitBtn.style.cursor = 'wait';
          submitBtn.textContent = currentLang === 'ru' ? 'Отправка...' :
                                   currentLang === 'pt' ? 'Enviando...' : 'Submitting...';
        });
      });
    }

    // Browser back/forward support
    window.addEventListener('popstate', function(e) {
      const lang = e.state?.lang || detectLanguageFromURL();
      switchLanguage(lang);
    });

    // Initialize when DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  </script>
</body>
</html>